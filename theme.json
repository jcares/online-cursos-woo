{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,

	"settings": {
		"appearanceTools": true,

		"layout": {
			"contentSize": "900px",
			"wideSize": "1200px"
		},

		"spacing": {
			"units": ["px","em","rem","%","vw"]
		},

		"typography": {
			"fontFamilies": [
				{
					"name": "Outfit",
					"slug": "outfit",
					"fontFamily": "Outfit, sans-serif"
				}
			]
		},

		"color": {
			"palette": [
				{
					"name": "Primario",
					"slug": "primary",
					"color": "#2563eb"
				},
				{
					"name": "Secundario",
					"slug": "secondary",
					"color": "#0f172a"
				},
				{
					"name": "Gris Claro",
					"slug": "light-gray",
					"color": "#f5f5f5"
				},
				{
					"name": "Blanco",
					"slug": "white",
					"color": "#ffffff"
				}
			]
		}
	},

	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--outfit)"
		}
	},

	"customTemplates": [
		{
			"name": "blank",
			"postTypes": ["page","post"],
			"title": "Plantilla en Blanco"
		},
		{
			"name": "page-no-title",
			"postTypes": ["page"],
			"title": "Página sin título"
		}
	],

	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Encabezado"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Pie de página"
		},
		{
			"area": "sidebar",
			"name": "sidebar",
			"title": "Barra lateral"
		}
	]
}